<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F6F8">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="28dp"
        android:paddingEnd="28dp"
        android:paddingBottom="28dp"
        android:paddingTop="70dp">

        <Button
            android:id="@+id/btnRegresarRegistro"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/regresar"
            android:textAllCaps="false"
            android:layout_marginBottom="18dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/crear_cuenta"
            android:textSize="30sp"
            android:textStyle="bold"
            android:textColor="#1E293B"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/subtitulo_registro"
            android:textSize="15sp"
            android:textColor="#374151"
            android:layout_marginBottom="28dp" />

        <EditText
            android:id="@+id/edtNombre"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:hint="@string/nombre"
            android:inputType="textPersonName"
            android:padding="14dp"
            android:textColor="#111827"
            android:textColorHint="#374151"
            android:background="@android:drawable/edit_text"
            android:layout_marginBottom="14dp" />

        <EditText
            android:id="@+id/edtEmailRegistro"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:hint="@string/correo_electronico"
            android:inputType="textEmailAddress"
            android:padding="14dp"
            android:textColor="#111827"
            android:textColorHint="#374151"
            android:background="@android:drawable/edit_text"
            android:layout_marginBottom="14dp" />

        <EditText
            android:id="@+id/edtPasswordRegistro"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:hint="@string/contrasena"
            android:inputType="textPassword"
            android:padding="14dp"
            android:textColor="#111827"
            android:textColorHint="#374151"
            android:background="@android:drawable/edit_text"
            android:layout_marginBottom="14dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/rol"
            android:textStyle="bold"
            android:textColor="#334155"
            android:layout_marginBottom="8dp" />

        <Spinner
            android:id="@+id/spinnerRol"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:background="@android:drawable/edit_text"
            android:padding="8dp"
            android:popupBackground="#FFFFFF"
            android:layout_marginBottom="22dp" />

        <Button
            android:id="@+id/btnRegistrar"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="@string/registrarme"
            android:textAllCaps="false"
            android:textSize="16sp" />

    </LinearLayout>

</ScrollView>